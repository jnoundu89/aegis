{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis",
  "version": "0.0.1",
  "identifier": "com.aegis.desktop",
  "build": {
    "frontendDist": "../web/build",
    "beforeBuildCommand": "TAURI_BUILD=1 pnpm --filter web build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "TAURI_BUILD=1 pnpm --filter web dev"
  },
  "app": {
    "windows": [
      {
        "title": "Aegis",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
