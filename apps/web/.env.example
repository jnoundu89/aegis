# Aegis – Environment Variables
# Copy this file to .env and fill in the values.
# All VITE_ variables are safe to expose client-side (baked in at build time by Vite).

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: https://supabase.com → Project → Settings → API

# Your project URL (e.g. https://xyzabc.supabase.co)
VITE_SUPABASE_URL=

# Public "anon" key – safe to expose (RLS policies enforce access control)
VITE_SUPABASE_ANON_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Admin login uses Supabase Auth magic links.
# Configure allowed emails in Supabase → Authentication → Users.
# Set the site URL to your deployment URL in Supabase → Authentication → URL Configuration.
